{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - QUI POTREBBERO ESSERCI GLI ERRORI */
    "strict": true,
    "noUnusedLocals": false,  // Cambia in false se hai errori su variabili non usate
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false // Se lo metti a FALSE, TypeScript smetterà di lamentarsi di 'any'
  }
}